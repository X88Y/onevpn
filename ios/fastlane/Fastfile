skip_docs

default_platform :ios

platform :ios do
  lane :deploy do
    build_app(
        skip_build_archive: true,
        archive_path: "../build/ios/archive/Runner.xcarchive",
        output_directory: File.expand_path('../../../output', __dir__),
        output_name: 'MVMVpn-ios',
        export_options: {
          method: 'app-store',
          provisioningProfiles: {
            'com.svyatvpn.app' => 'MVMVpniOS',
            'com.svyatvpn.app.tun' => 'MVMVpnTuniOS'
          }
        })
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch('FASTLANE_ASC_KEY_ID'),
      issuer_id: ENV.fetch('FASTLANE_ASC_ISSUER_ID'),
      key_filepath: './fastlane/AuthKey.p8'
    )
    upload_to_testflight(
      api_key: api_key
    )
  end

  after_all do |lane|
  end

  error do |lane, exception|
  end
end
